# LLM provider
# mock: API 키 없이 로컬 개발 및 전체 흐름 확인
# openai: 현재 1차 MVP 실제 사용 provider
# gemini: 추후 비교 검증을 위한 대체 provider
LLM_PROVIDER=mock  # openai | gemini | mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Local frontend
FRONTEND_ORIGIN=http://localhost:5173
